# Токен от @BotFather в Telegram
BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ваш Telegram user_id (для команды /stats)
# Узнать: написать @userinfobot
ADMIN_ID=123456789

# Время ежедневной рассылки (по МСК)
DAILY_HOUR=9
DAILY_MINUTE=0

# Токен платёжного провайдера (Telegram Payments)
# Получить у @BotFather → Payments → подключить провайдера
# Для тестирования используйте тестовый токен провайдера
PAYMENT_PROVIDER_TOKEN=

# Цена подписки в копейках (29900 = 299 ₽)
SUBSCRIPTION_PRICE=29900
